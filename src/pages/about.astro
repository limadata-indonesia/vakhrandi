---
import Layout from '../layouts/Layout.astro'
import { getCollection } from 'astro:content'

const settingsEntries = await getCollection('settings')
const artist = settingsEntries[0].data
---

<Layout title={`About — ${artist.name}`} description={artist.bio}>

  <section class="py-20 px-6 bg-[#F9F8F6] text-center">
    <p class="text-xs font-bold uppercase tracking-[0.3em] text-[#C4A35A] mb-3">The Artist</p>
    <h1 class="text-5xl font-black text-[#0D0C0E] mb-4">About</h1>
    <p class="text-[#6B6475] max-w-md mx-auto">The story, the sound, the journey.</p>
  </section>

  <div class="max-w-4xl mx-auto px-6 py-20 space-y-20">

    <!-- Biography -->
    <div class="grid md:grid-cols-2 gap-12 items-start">
      <div>
        <div class="w-full aspect-square bg-[#E8E4DE] rounded-2xl flex items-center justify-center text-6xl text-[#6B6475] font-black">
          {artist.name[0]}
        </div>
      </div>
      <div>
        <p class="text-xs font-bold uppercase tracking-[0.3em] text-[#C4A35A] mb-4">Biography</p>
        <p class="text-[#0D0C0E] leading-relaxed mb-4">{artist.bio}</p>
        {artist.bioExtended && (
          <p class="text-[#6B6475] leading-relaxed">{artist.bioExtended}</p>
        )}
      </div>
    </div>

    <!-- Career Journey -->
    {artist.milestones.length > 0 && (
      <div>
        <p class="text-xs font-bold uppercase tracking-[0.3em] text-[#C4A35A] mb-8">Career Journey</p>
        <div class="relative pl-6 border-l border-gray-200 space-y-8">
          {artist.milestones.map(({ year, event }) => (
            <div class="relative">
              <div class="absolute -left-[1.625rem] w-3 h-3 rounded-full bg-[#C4A35A] border-2 border-white"></div>
              <span class="text-xs font-bold text-[#C4A35A] tracking-widest uppercase">{year}</span>
              <p class="text-[#0D0C0E] font-medium mt-1">{event}</p>
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Influences -->
    {artist.influences.length > 0 && (
      <div>
        <p class="text-xs font-bold uppercase tracking-[0.3em] text-[#C4A35A] mb-6">Musical Influences</p>
        <div class="flex flex-wrap gap-3">
          {artist.influences.map(name => (
            <span class="px-4 py-2 bg-[#F9F8F6] border border-gray-200 rounded-full text-sm font-semibold text-[#0D0C0E]">
              {name}
            </span>
          ))}
        </div>
      </div>
    )}

    <!-- Achievements -->
    {artist.achievements.length > 0 && (
      <div>
        <p class="text-xs font-bold uppercase tracking-[0.3em] text-[#C4A35A] mb-6">Achievements</p>
        <ul class="space-y-3">
          {artist.achievements.map(item => (
            <li class="flex items-start gap-3">
              <span class="text-[#C4A35A] font-bold mt-0.5">✦</span>
              <span class="text-[#0D0C0E] font-medium">{item}</span>
            </li>
          ))}
        </ul>
      </div>
    )}

  </div>
</Layout>
