---
import Layout from '../layouts/Layout.astro'
import { getCollection } from 'astro:content'

const releasesRaw = await getCollection('releases')
const releases = releasesRaw.sort((a, b) => a.data.order - b.data.order)

type ReleaseType = 'Single' | 'EP' | 'Album' | 'Collaboration'
const filters: ReleaseType[] = ['Single', 'EP', 'Album', 'Collaboration']
---

<Layout title="Music — VAKHRANDI" description="Full catalog of VAKHRANDI releases.">

  <section class="py-20 px-6 bg-[#F9F8F6] text-center">
    <p class="text-xs font-bold uppercase tracking-[0.3em] text-[#C4A35A] mb-3">Discography</p>
    <h1 class="text-5xl font-black text-[#0D0C0E] mb-4">Music</h1>
    <p class="text-[#6B6475] max-w-md mx-auto">Every release, every drop — all in one place.</p>
  </section>

  <div class="max-w-5xl mx-auto px-6 py-16">

    <div class="flex flex-wrap gap-2 mb-12">
      <button data-filter="all" class="filter-btn px-4 py-2 rounded-full text-sm font-semibold border border-[#0D0C0E] bg-[#0D0C0E] text-white transition-all">All</button>
      {filters.map(f => (
        <button data-filter={f} class="filter-btn px-4 py-2 rounded-full text-sm font-semibold border border-gray-200 text-[#6B6475] hover:border-[#0D0C0E] hover:text-[#0D0C0E] transition-all">{f}</button>
      ))}
    </div>

    <div class="space-y-6">
      {releases.map(({ data }) => (
        <article data-type={data.type} class="release-card flex flex-col sm:flex-row gap-6 p-6 border border-gray-100 rounded-2xl hover:border-gray-300 transition-all bg-white">
          <div class="flex-shrink-0 w-24 h-24 bg-[#E8E4DE] rounded-xl flex items-center justify-center overflow-hidden">
            {data.cover && data.cover !== '/images/placeholder-release.jpg'
              ? <img src={data.cover} alt={data.title} class="w-full h-full object-cover" />
              : <span class="text-2xl">🎵</span>
            }
          </div>
          <div class="flex-1 min-w-0">
            <div class="flex items-start justify-between gap-4 flex-wrap mb-1">
              <h2 class="text-xl font-black text-[#0D0C0E]">{data.title}</h2>
              <span class="text-xs font-bold uppercase tracking-widest text-[#C4A35A] bg-[#EDE0C4] px-3 py-1 rounded-full flex-shrink-0">{data.type}</span>
            </div>
            <p class="text-xs text-[#6B6475] font-medium mb-2">Released {data.year} · {data.duration}</p>
            <p class="text-sm text-[#6B6475] leading-relaxed mb-4">{data.description}</p>
            <div class="flex flex-wrap gap-2">
              {data.links.map(({ platform, url }) => (
                <a href={url} class="inline-flex items-center gap-1.5 text-xs font-semibold border border-gray-200 px-3 py-1.5 rounded-full hover:bg-[#0D0C0E] hover:text-white hover:border-[#0D0C0E] transition-all">
                  ▶ {platform}
                </a>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>

  </div>
</Layout>

<script>
  const btns = document.querySelectorAll<HTMLButtonElement>('.filter-btn')
  const cards = document.querySelectorAll<HTMLElement>('.release-card')
  btns.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter!
      btns.forEach(b => { b.classList.remove('bg-[#0D0C0E]','text-white','border-[#0D0C0E]'); b.classList.add('border-gray-200','text-[#6B6475]') })
      btn.classList.add('bg-[#0D0C0E]','text-white','border-[#0D0C0E]'); btn.classList.remove('border-gray-200','text-[#6B6475]')
      cards.forEach(c => { c.style.display = (filter === 'all' || c.dataset.type === filter) ? '' : 'none' })
    })
  })
</script>
