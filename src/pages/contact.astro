---
import Layout from '../layouts/Layout.astro'

const categories = [
  'Booking Show',
  'Collaboration',
  'Interview',
  'Sponsorship',
  'Other',
]
---

<Layout title="Contact — VAKHRANDI" description="Booking, collaboration, interview and sponsorship inquiries for VAKHRANDI.">

  <section class="py-20 px-6 bg-[#F9F8F6] text-center">
    <p class="text-xs font-bold uppercase tracking-[0.3em] text-[#C4A35A] mb-3">Get in Touch</p>
    <h1 class="text-5xl font-black text-[#0D0C0E] mb-4">Contact</h1>
    <p class="text-[#6B6475] max-w-md mx-auto">For bookings, collabs, interviews, and partnerships.</p>
  </section>

  <div class="max-w-2xl mx-auto px-6 py-16">

    <form
      id="contact-form"
      class="space-y-5 bg-white border border-gray-100 rounded-2xl p-8"
      novalidate
    >
      <div>
        <label class="block text-xs font-bold uppercase tracking-widest text-[#6B6475] mb-2">Name *</label>
        <input
          type="text"
          name="name"
          required
          placeholder="Your name"
          class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm text-[#0D0C0E] outline-none focus:border-[#0D0C0E] focus:ring-2 focus:ring-[#0D0C0E]/5 transition"
        />
      </div>

      <div>
        <label class="block text-xs font-bold uppercase tracking-widest text-[#6B6475] mb-2">Email *</label>
        <input
          type="email"
          name="email"
          required
          placeholder="you@example.com"
          class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm text-[#0D0C0E] outline-none focus:border-[#0D0C0E] focus:ring-2 focus:ring-[#0D0C0E]/5 transition"
        />
      </div>

      <div>
        <label class="block text-xs font-bold uppercase tracking-widest text-[#6B6475] mb-2">Category *</label>
        <select
          name="category"
          required
          class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm text-[#0D0C0E] outline-none focus:border-[#0D0C0E] bg-white appearance-none transition"
        >
          <option value="">Select a category...</option>
          {categories.map(c => <option value={c}>{c}</option>)}
        </select>
      </div>

      <div>
        <label class="block text-xs font-bold uppercase tracking-widest text-[#6B6475] mb-2">Subject *</label>
        <input
          type="text"
          name="subject"
          required
          placeholder="Brief subject line"
          class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm text-[#0D0C0E] outline-none focus:border-[#0D0C0E] focus:ring-2 focus:ring-[#0D0C0E]/5 transition"
        />
      </div>

      <div>
        <label class="block text-xs font-bold uppercase tracking-widest text-[#6B6475] mb-2">Message *</label>
        <textarea
          name="message"
          required
          rows={5}
          placeholder="Tell us what you have in mind..."
          class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm text-[#0D0C0E] outline-none focus:border-[#0D0C0E] focus:ring-2 focus:ring-[#0D0C0E]/5 transition resize-none"
        />
      </div>

      <button
        type="submit"
        class="w-full bg-[#0D0C0E] text-white font-black py-4 rounded-full hover:bg-[#C4A35A] transition-colors text-sm"
      >
        Send Message →
      </button>

      <div id="form-success" class="hidden text-center py-4">
        <p class="font-black text-[#0D0C0E] mb-1">Message sent!</p>
        <p class="text-sm text-[#6B6475]">We'll get back to you as soon as possible.</p>
      </div>
    </form>

  </div>
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement
  const success = document.getElementById('form-success')!

  form.addEventListener('submit', async (e) => {
    e.preventDefault()
    // Replace with your form handler (Formspree, Netlify Forms, etc.)
    // For now just show success message
    form.querySelectorAll('input, select, textarea, button[type="submit"]').forEach(el => {
      (el as HTMLElement).setAttribute('disabled', '')
    })
    success.classList.remove('hidden')
  })
</script>
