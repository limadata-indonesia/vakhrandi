---
import Layout from '../layouts/Layout.astro'
import { getCollection } from 'astro:content'

const photosRaw = await getCollection('gallery')
const photos = photosRaw.sort((a, b) => a.data.order - b.data.order)

const categories = ['Photoshoot', 'Live Performance', 'Behind The Scene', 'Studio Session', 'Fan Event']
---

<Layout title="Gallery — VAKHRANDI" description="Photo gallery — photoshoots, live performances, studio sessions and more.">

  <section class="py-20 px-6 bg-[#F9F8F6] text-center">
    <p class="text-xs font-bold uppercase tracking-[0.3em] text-[#C4A35A] mb-3">Visuals</p>
    <h1 class="text-5xl font-black text-[#0D0C0E] mb-4">Gallery</h1>
    <p class="text-[#6B6475] max-w-md mx-auto">Behind the music, in front of the lens.</p>
  </section>

  <div class="max-w-6xl mx-auto px-6 py-16">

    <div class="flex flex-wrap gap-2 mb-10">
      <button data-filter="all" class="filter-btn px-4 py-2 rounded-full text-sm font-semibold bg-[#0D0C0E] text-white border border-[#0D0C0E] transition-all">All</button>
      {categories.map(c => (
        <button data-filter={c} class="filter-btn px-4 py-2 rounded-full text-sm font-semibold border border-gray-200 text-[#6B6475] hover:border-[#0D0C0E] hover:text-[#0D0C0E] transition-all">{c}</button>
      ))}
    </div>

    {photos.length > 0 ? (
      <div class="columns-2 md:columns-3 lg:columns-4 gap-4">
        {photos.map(({ data }, i) => (
          <div
            data-category={data.category}
            class="gallery-item break-inside-avoid mb-4 overflow-hidden rounded-xl bg-[#E8E4DE] cursor-pointer group relative"
          >
            {data.src ? (
              <img src={data.src} alt={data.alt} class={`w-full object-cover ${i % 3 === 0 ? 'aspect-square' : i % 3 === 1 ? 'aspect-[3/4]' : 'aspect-[4/3]'}`} loading="lazy" />
            ) : (
              <div class={`w-full bg-[#E8E4DE] flex items-center justify-center text-[#6B6475] font-bold text-sm ${i % 3 === 0 ? 'aspect-square' : i % 3 === 1 ? 'aspect-[3/4]' : 'aspect-[4/3]'}`}>
                {data.alt}
              </div>
            )}
            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/30 transition-all flex items-end p-3">
              <span class="text-white text-xs font-semibold opacity-0 group-hover:opacity-100 transition-opacity bg-black/50 px-3 py-1 rounded-full">
                {data.category}
              </span>
            </div>
          </div>
        ))}
      </div>
    ) : (
      <div class="text-center py-20 text-[#6B6475]">
        <p class="text-lg font-semibold mb-2">No photos yet</p>
        <p class="text-sm">Add photos via the <a href="/admin" class="text-[#C4A35A] underline">CMS</a>.</p>
      </div>
    )}

  </div>

  <!-- Lightbox -->
  <div id="lightbox" class="fixed inset-0 z-50 bg-black/90 hidden items-center justify-center p-6">
    <button id="lb-close" class="absolute top-6 right-6 text-white text-3xl font-light hover:text-[#C4A35A] transition-colors">✕</button>
    <img id="lb-img" src="" alt="" class="max-w-3xl max-h-[80vh] rounded-xl object-contain" />
  </div>
</Layout>

<script>
  const btns = document.querySelectorAll<HTMLButtonElement>('.filter-btn')
  const items = document.querySelectorAll<HTMLElement>('.gallery-item')
  const lightbox = document.getElementById('lightbox')!
  const lbClose  = document.getElementById('lb-close')!
  const lbImg    = document.getElementById('lb-img') as HTMLImageElement

  btns.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter!
      btns.forEach(b => { b.classList.remove('bg-[#0D0C0E]','text-white','border-[#0D0C0E]'); b.classList.add('border-gray-200','text-[#6B6475]') })
      btn.classList.add('bg-[#0D0C0E]','text-white','border-[#0D0C0E]'); btn.classList.remove('border-gray-200','text-[#6B6475]')
      items.forEach(i => { i.style.display = (filter === 'all' || i.dataset.category === filter) ? '' : 'none' })
    })
  })

  items.forEach(item => {
    item.addEventListener('click', () => {
      const img = item.querySelector('img')
      if (img) { lbImg.src = img.src; lbImg.alt = img.alt }
      lightbox.classList.remove('hidden'); lightbox.classList.add('flex')
    })
  })

  const closeLb = () => { lightbox.classList.add('hidden'); lightbox.classList.remove('flex') }
  lbClose.addEventListener('click', closeLb)
  lightbox.addEventListener('click', e => { if (e.target === lightbox) closeLb() })
</script>
