---
import Layout from '../layouts/Layout.astro'
import { client } from '../lib/sanity'

const videos = await client.fetch(`*[_type == "video"] | order(order asc)`)
const categories = ['Music Video', 'Lyric Video', 'Shorts', 'Live Session']
---

<Layout title="Video — VAKHRANDI" description="Official VAKHRANDI music videos, lyric videos, shorts and live sessions.">

  <section class="py-20 px-6 bg-[#F9F8F6] text-center">
    <p class="text-xs font-bold uppercase tracking-[0.3em] text-[#C4A35A] mb-3">Watch</p>
    <h1 class="text-5xl font-black text-[#0D0C0E] mb-4">Video</h1>
    <p class="text-[#6B6475] max-w-md mx-auto">Official videos, live sets, and behind-the-scenes.</p>
  </section>

  <div class="max-w-6xl mx-auto px-6 py-16">
    <div class="flex flex-wrap gap-2 mb-10">
      <button data-filter="all" class="filter-btn px-4 py-2 rounded-full text-sm font-semibold bg-[#0D0C0E] text-white border border-[#0D0C0E] transition-all">All</button>
      {categories.map(c => (
        <button data-filter={c} class="filter-btn px-4 py-2 rounded-full text-sm font-semibold border border-gray-200 text-[#6B6475] hover:border-[#0D0C0E] hover:text-[#0D0C0E] transition-all">{c}</button>
      ))}
    </div>

    <div class="grid md:grid-cols-2 gap-6">
      {videos.map((v: any) => (
        <article data-category={v.category} class="video-item border border-gray-100 rounded-2xl overflow-hidden hover:border-gray-300 hover:shadow-lg transition-all">
          {v.youtubeId ? (
            <div class="aspect-video">
              <iframe src={`https://www.youtube.com/embed/${v.youtubeId}`} title={v.title} frameBorder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowFullscreen class="w-full h-full" />
            </div>
          ) : (
            <div class="aspect-video bg-[#E8E4DE] flex flex-col items-center justify-center gap-2">
              <span class="text-3xl">▶</span>
              <span class="text-sm text-[#6B6475] font-medium">Coming soon</span>
            </div>
          )}
          <div class="p-4">
            <div class="flex items-start justify-between gap-2">
              <h3 class="font-black text-[#0D0C0E] text-sm leading-snug">{v.title}</h3>
              <span class="flex-shrink-0 text-[10px] font-bold uppercase tracking-widest text-[#C4A35A] bg-[#EDE0C4] px-2 py-0.5 rounded-full">{v.category}</span>
            </div>
            <p class="text-xs text-[#6B6475] mt-1">{v.year}</p>
          </div>
        </article>
      ))}
    </div>

    <div class="mt-16 text-center">
      <a href="#" class="inline-flex items-center gap-2 bg-[#FF0000] text-white font-bold px-8 py-4 rounded-full hover:bg-red-700 transition-colors">
        ▶ Subscribe on YouTube
      </a>
    </div>
  </div>
</Layout>

<script>
  const btns = document.querySelectorAll<HTMLButtonElement>('.filter-btn')
  const items = document.querySelectorAll<HTMLElement>('.video-item')
  btns.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter!
      btns.forEach(b => { b.classList.remove('bg-[#0D0C0E]','text-white','border-[#0D0C0E]'); b.classList.add('border-gray-200','text-[#6B6475]') })
      btn.classList.add('bg-[#0D0C0E]','text-white','border-[#0D0C0E]'); btn.classList.remove('border-gray-200','text-[#6B6475]')
      items.forEach(i => { i.style.display = (filter === 'all' || i.dataset.category === filter) ? '' : 'none' })
    })
  })
</script>
