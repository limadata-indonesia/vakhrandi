---
const socials = [
  { label: 'Spotify',    href: '#' },
  { label: 'Instagram',  href: '#' },
  { label: 'TikTok',     href: '#' },
  { label: 'YouTube',    href: '#' },
  { label: 'Apple Music',href: '#' },
]
---

<footer class="border-t border-gray-100 py-12 mt-24">
  <div class="max-w-7xl mx-auto px-6">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">

      <div class="text-center md:text-left">
        <div class="font-black text-lg tracking-[0.15em] text-[#0D0C0E] mb-1">VAKHRANDI</div>
        <p class="text-sm text-[#6B6475]">© {new Date().getFullYear()} VAKHRANDI. All rights reserved.</p>
      </div>

      <div class="flex flex-wrap justify-center gap-4">
        {socials.map(({ label, href }) => (
          <a
            href={href}
            class="text-sm text-[#6B6475] hover:text-[#0D0C0E] transition-colors font-medium"
          >
            {label}
          </a>
        ))}
      </div>

      <div class="flex gap-4 text-sm text-[#6B6475]">
        <a href="/press-kit" class="hover:text-[#0D0C0E] transition-colors">Press Kit</a>
        <a href="/contact" class="hover:text-[#0D0C0E] transition-colors">Contact</a>
      </div>

    </div>
  </div>
</footer>
