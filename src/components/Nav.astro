---
const links = [
  { href: '/',          label: 'Home'      },
  { href: '/about',     label: 'About'     },
  { href: '/music',     label: 'Music'     },
  { href: '/listen',    label: 'Listen'    },
  { href: '/gallery',   label: 'Gallery'   },
  { href: '/merch',     label: 'Merch'     },
  { href: '/video',     label: 'Video'     },
  { href: '/social',    label: 'Social'    },
  { href: '/press-kit', label: 'Press Kit' },
  { href: '/contact',   label: 'Contact'   },
]

const path = Astro.url.pathname
---

<header id="nav" class="fixed top-0 inset-x-0 z-50 transition-all duration-300">
  <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between gap-8">

    <!-- Logo -->
    <a href="/" class="font-black text-lg tracking-[0.15em] text-[#0D0C0E] hover:text-[#C4A35A] transition-colors">
      VAKHRANDI
    </a>

    <!-- Desktop nav -->
    <nav class="hidden lg:flex items-center gap-1">
      {links.map(({ href, label }) => (
        <a
          href={href}
          class={`px-3 py-1.5 rounded-full text-sm font-semibold transition-colors ${
            path === href
              ? 'bg-[#0D0C0E] text-white'
              : 'text-[#6B6475] hover:text-[#0D0C0E]'
          }`}
        >
          {label}
        </a>
      ))}
    </nav>

    <!-- Mobile hamburger -->
    <button id="menu-toggle" class="lg:hidden p-2 -mr-2" aria-label="Menu">
      <span class="block w-5 h-px bg-[#0D0C0E] mb-1.5 transition-all" id="bar1"></span>
      <span class="block w-5 h-px bg-[#0D0C0E] mb-1.5 transition-all" id="bar2"></span>
      <span class="block w-5 h-px bg-[#0D0C0E] transition-all" id="bar3"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden lg:hidden bg-white border-t border-gray-100 px-6 py-4">
    {links.map(({ href, label }) => (
      <a
        href={href}
        class={`block py-2.5 text-sm font-semibold border-b border-gray-50 last:border-0 ${
          path === href ? 'text-[#0D0C0E]' : 'text-[#6B6475]'
        }`}
      >
        {label}
      </a>
    ))}
  </div>
</header>

<!-- Spacer so content clears the fixed nav -->
<div class="h-16"></div>

<script>
  const nav = document.getElementById('nav')!
  const toggle = document.getElementById('menu-toggle')!
  const menu = document.getElementById('mobile-menu')!

  // Scroll: add white bg + shadow
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      nav.classList.add('bg-white/95', 'backdrop-blur-sm', 'shadow-sm')
    } else {
      nav.classList.remove('bg-white/95', 'backdrop-blur-sm', 'shadow-sm')
    }
  }, { passive: true })

  toggle.addEventListener('click', () => {
    menu.classList.toggle('hidden')
  })
</script>
